   CustomOptions := &apos;-dUseCThreads -dUseStatusIcon&apos;;"/>
    <BuildMacros>
      <Count Value="1"/>
      <Item1>
        <Identifier Value="Macro"/>
      </Item1>
    </BuildMacros>
    <Parsing>
      <SyntaxOptions>
        <IncludeAssertionCode Value="True"/>
      </SyntaxOptions>
    </Parsing>
    <CodeGeneration>
      <Checks>
        <IOChecks Value="True"/>
        <OverflowChecks Value="True"/>
        <StackChecks Value="True"/>
      </Checks>
      <Optimizations>
        <OptimizationLevel Value="2"/>
      </Optimizations>
    </CodeGeneration>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf2"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
    <Other>
      <ConfigFile>
        <ConfigFilePath Value="..\extrafpc.cfg"/>
      </ConfigFile>
      <CustomOptions Value="-Xm"/>
      <ExecuteBefore>
        <Command Value="$(LazarusDir)\tools\svn2revisioninc$(ExeExt) .. ovorevision.inc --c=ovoRevision"/>
      </ExecuteBefore>
    </Other>
  </CompilerOptions>
